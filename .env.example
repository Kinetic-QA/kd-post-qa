# ─── JIRA Cloud Credentials ──────────────────────────────────────────────────
# Your Atlassian account email
JIRA_EMAIL=your-email@kineticdigital.com

# API token from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-api-token-here

# Your JIRA Cloud base URL (no trailing slash)
JIRA_BASE_URL=https://your-org.atlassian.net

# ─── JIRA Workflow Transitions ───────────────────────────────────────────────
# Verified against prime-online.atlassian.net SC project (see JIRAWorkflow.png)
# Run `npx ts-node src/check-transitions.ts <TICKET-KEY>` to verify IDs for your project.
#
# ── Linear flow ──────────────────────────────────────────────────────────────
JIRA_TRANSITION_START_PROGRESS=31        # To Do          → In Progress
JIRA_TRANSITION_DEV_DONE=41             # In Progress     → Dev Done
JIRA_TRANSITION_READY_FOR_QA=51         # Dev Done        → Ready for QA
JIRA_TRANSITION_IN_REVIEW=71            # Ready for QA    → In Review
JIRA_TRANSITION_APPROVED=101            # In Review       → Approved by QA
JIRA_TRANSITION_RELEASED=111            # Approved        → Closed (Released on production)
#
# ── QA rejection path ────────────────────────────────────────────────────────
JIRA_TRANSITION_QA_REJECTED=81          # In Review       → Reopened
JIRA_TRANSITION_BACK_TO_IN_PROGRESS=91  # Reopened        → In Progress
JIRA_TRANSITION_QA_REJECTED_BY_DEV=161  # Reopened        → QA Rejected by Dev
#
# ── Post-release path ────────────────────────────────────────────────────────
JIRA_TRANSITION_POST_RELEASE_QA=181     # Approved        → Post Release QA
JIRA_TRANSITION_POST_RELEASE_CLOSED=191 # Post Release QA → Closed
#
# ── Production QA / skip QA paths ────────────────────────────────────────────
JIRA_TRANSITION_PRODUCTION_QA=61        # Dev Done        → Production QA
JIRA_TRANSITION_DONE_NO_QA=131          # Dev Done        → Done (no QA required)
#
# ── Other states ─────────────────────────────────────────────────────────────
JIRA_TRANSITION_REJECTED=151            # To Do           → Rejected
#
# ── Global (available from any state) ────────────────────────────────────────
JIRA_TRANSITION_ON_HOLD=11              # Any             → On Hold
JIRA_TRANSITION_CANCELLED=21            # Any             → Cancelled
JIRA_TRANSITION_TO_DO=141               # Any             → To Do

# ─── QA Site ─────────────────────────────────────────────────────────────────
QA_BASE_URL=https://qa.slingo.com

# ─── AI Ticket Interpreter (Option 2) ────────────────────────────────────────
# Optional. When set, the agent uses Claude to interpret free-form ticket
# descriptions — no "Test Type:" line required.
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─── Tracking Tag Checks (injected automatically by the agent) ───────────────
# Do NOT set these manually — the agent extracts and injects them from the ticket.
QA_TAG_ID=
QA_QA_BASE_URL=
QA_BRAND=
QA_GEO=

# ─── Strapi CMS Credentials (per brand) ──────────────────────────────────────
# Only these 9 brands run a Strapi CMS — other brands have no CMS to check.
# For each brand, set EITHER:
#   <PREFIX>_TOKEN                       (preferred — scoped API token)
# OR
#   <PREFIX>_USERNAME + <PREFIX>_PASSWORD (fallback — personal admin login)
# Never commit real values here — this file only holds placeholders.

