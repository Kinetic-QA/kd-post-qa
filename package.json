{
  "name": "revwright-sanity-tests",
  "version": "1.0.0",
  "description": "Playwright automation for ZingoBingo sanity checklist",
  "scripts": {
    "test": "playwright test",
    "test:p1": "playwright test tests/p1/",
    "test:p2": "playwright test tests/p2/",
    "test:p3": "playwright test tests/p3/",
    "test:uk": "cross-env TEST_GEO=UK playwright test tests/p1 tests/p2 tests/p3",
    "test:es": "cross-env TEST_GEO=ES playwright test tests/p1 tests/p2 tests/p3",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "report:excel": "python generate-report.py",
    "agent": "ts-node src/agent.ts",
    "check-transitions": "ts-node src/check-transitions.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "form-data": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^25.9.1",
    "cross-env": "^10.1.0",
    "exceljs": "^4.4.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.5"
  },
  "overrides": {
    "uuid": ">=11.1.1"
  }
}
